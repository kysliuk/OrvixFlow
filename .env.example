# OrvixFlow Environment Configuration Template
# Copy this file to .env and replace the placeholder values with real secrets

# Database
POSTGRES_USER=orvix_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=orvixflow

# JWT Configuration (REQUIRED - generate a secure 64-character random string)
JWT_SECRET=REPLACE-WITH-A-64-CHAR-RANDOM-SECRET-IN-PRODUCTION-ENVIRONMENT
JWT_ISSUER=orvixflow
JWT_AUDIENCE=orvixflow-web

# OAuth Providers (REPLACE WITH REAL VALUES FROM GOOGLE CLOUD CONSOLE / AZURE PORTAL)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
AZURE_AD_CLIENT_ID=your_azure_client_id
AZURE_AD_CLIENT_SECRET=your_azure_client_secret

# Email Delivery
# Valid values: Console, Smtp, Resend
EMAIL_PROVIDER=Console
EMAIL_FROM_EMAIL=noreply@orvixflow.local
EMAIL_FROM_NAME="OrvixFlow Identity"
EMAIL_SMTP_HOST=
EMAIL_SMTP_PORT=25
EMAIL_SMTP_USER=
EMAIL_SMTP_PASS=
EMAIL_USE_SSL=true
# Email Delivery — Resend (production recommended)
# Get API key from https://resend.com/api-keys
# EMAIL_PROVIDER=Resend uses this key to send via the Resend API
EMAIL_RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_RESEND_BASE_URL=https://api.resend.com

# Resend requires a verified sending domain.
# Set EMAIL_FROM_EMAIL to an address at your verified domain.
# Example: noreply@yourdomain.com
# EMAIL_PROVIDER=Resend will fail with 403 if the domain is not verified.

# n8n Automation
N8N_BASE_URL=http://orvix-n8n:5678
# n8n Instance Owner Authentication (REQUIRED in production)
N8N_OWNER_EMAIL=admin@orvixflow.local
N8N_OWNER_FIRST_NAME=Orvix
N8N_OWNER_LAST_NAME=Admin
# Generate with: docker run --rm httpd:2.4-alpine htpasswd -nbBC 10 "" "your-password" | tr -d ':\n'
N8N_OWNER_PASSWORD_HASH=REPLACE-WITH-A-BCRYPT-HASH
N8N_ENCRYPTION_KEY=REPLACE-WITH-A-64-CHAR-RANDOM-KEY
AUTOMATION_KEY=your_automation_key_here

# NextAuth (REQUIRED - generate a secure random string)
NEXTAUTH_SECRET=your_nextauth_secret_here
AUTH_SECRET=your_auth_secret_here

# AI Provider
AI_PROVIDER=OpenAI
AI_OPENAI_API_KEY=your_openai_api_key_here

# Virus Scanning
VIRUS_SCAN_PROVIDER=ClamAv

# Object Storage (MinIO for local/dev)
STORAGE_PROVIDER=MinIO
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_BUCKET=orvixflow

# ─── Stripe Configuration (Test Mode) ────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_test_key_here
# Stripe Webhook Secret (REQUIRED — get from Stripe dashboard → Webhooks → signing secret)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here
STRIPE_PRICE_BUSINESS_MONTHLY=price_business_monthly_id
STRIPE_PRICE_BUSINESS_YEARLY=price_business_yearly_id

# Mailbox OAuth Configuration
# Key must be a base64-encoded 32-byte (256-bit) random key. Generate with: openssl rand -base64 32
MAILBOX_CREDENTIAL_ENCRYPTION_KEY=REPLACE-WITH-BASE64-32-BYTE-RANDOM-KEY

MAILBOX_GOOGLE_CLIENT_ID=your_google_mailbox_client_id.apps.googleusercontent.com
MAILBOX_GOOGLE_CLIENT_SECRET=your_google_mailbox_client_secret
MAILBOX_GOOGLE_REDIRECT_URI=http://localhost:3000/mailbox-callback

MAILBOX_MICROSOFT_CLIENT_ID=your_microsoft_mailbox_client_id
MAILBOX_MICROSOFT_CLIENT_SECRET=your_microsoft_mailbox_client_secret
MAILBOX_MICROSOFT_REDIRECT_URI=http://localhost:3000/mailbox-callback

