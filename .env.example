# OrvixFlow Environment Configuration Template
# Copy this file to .env and replace the placeholder values with real secrets

# Database
POSTGRES_USER=orvix_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=orvixflow

# JWT Configuration (REQUIRED - generate a secure 64-character random string)
JWT_SECRET=REPLACE-WITH-A-64-CHAR-RANDOM-SECRET-IN-PRODUCTION-ENVIRONMENT
JWT_ISSUER=orvixflow
JWT_AUDIENCE=orvixflow-web

# OAuth Providers (REPLACE WITH REAL VALUES FROM GOOGLE CLOUD CONSOLE / AZURE PORTAL)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
AZURE_AD_CLIENT_ID=your_azure_client_id
AZURE_AD_CLIENT_SECRET=your_azure_client_secret

# n8n Automation
N8N_BASE_URL=http://orvix-n8n:5678
AUTOMATION_KEY=your_secure_automation_key_here

# NextAuth (REQUIRED - generate a secure random string)
NEXTAUTH_SECRET=your_nextauth_secret_here

# AI Provider
AI_PROVIDER=OpenAI
AI_OPENAI_API_KEY=your_openai_or_groq_api_key

# ─── Stripe Configuration (Test Mode) ────────────────────────────────────────
# Get keys from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_test_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Price IDs — create in Stripe Dashboard per STRIPE_SETUP_GUIDE.md
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly_id
STRIPE_PRICE_STARTER_YEARLY=price_starter_yearly_id
STRIPE_PRICE_GROWTH_MONTHLY=price_growth_monthly_id
STRIPE_PRICE_GROWTH_YEARLY=price_growth_yearly_id
STRIPE_PRICE_BUSINESS_MONTHLY=price_business_monthly_id
STRIPE_PRICE_BUSINESS_YEARLY=price_business_yearly_id
