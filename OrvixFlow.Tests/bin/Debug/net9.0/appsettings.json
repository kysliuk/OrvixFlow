{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "orvixflow",
    "Audience": "orvixflow-web"
  },
  "Frontend": {
    "BaseUrl": "http://localhost:3000"
  },
  "Automation": {
    "N8nBaseUrl": "http://localhost:5678"
  },
  "Storage": {
    "Provider": "Local",
    "MinIO": {
      "Endpoint": "http://minio:9000",
      "Bucket": "orvixflow",
      "UseSSL": false
    },
    "Local": {
      "BasePath": "/app/uploads"
    }
  },
  "Security": {
    "VirusScan": {
      "Provider": "Noop",
      "ClamAv": {
        "Host": "localhost",
        "Port": 3310,
        "ConnectTimeoutSeconds": 30,
        "ReadWriteTimeoutSeconds": 60
      }
    }
  }
}
