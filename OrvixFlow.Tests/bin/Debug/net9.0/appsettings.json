{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Secret": "REPLACE-WITH-A-64-CHAR-RANDOM-SECRET-IN-PRODUCTION-ENVIRONMENT",
    "Issuer": "orvixflow",
    "Audience": "orvixflow-web"
  },
  "Frontend": {
    "BaseUrl": "http://localhost:3000"
  },
  "Automation": {
    "N8nBaseUrl": "http://localhost:5678"
  },
  "Security": {
    "VirusScan": {
      "Provider": "Noop",
      "ClamAv": {
        "Host": "localhost",
        "Port": 3310,
        "ConnectTimeoutSeconds": 30,
        "ReadWriteTimeoutSeconds": 60
      }
    }
  }
}
